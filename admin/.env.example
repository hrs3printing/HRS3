# Build-time: copy to .env before `npm run build`

# Must match the storefront / server API (include /api)
VITE_API_URL=/api

# "Back to store" link — customer site public URL
VITE_STORE_URL=https://hrs3.in

# If you deploy the admin app under /admin on the same host as the API,
# build with: VITE_BASE=/admin/ npm run build
# (see repo root package.json script `build:admin:subpath`)
