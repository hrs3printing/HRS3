# Build-time: copy to .env and set before `npm run build`

# Public API (must include /api). Same-origin example if nginx proxies /api to Node:
# VITE_API_URL=/api
# Or full URL to your API:
# VITE_API_URL=https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# Navbar "Admin" link. Same host as storefront:
# VITE_ADMIN_URL=https://yourdomain.com/admin
# Or separate admin subdomain:
# VITE_ADMIN_URL=https://admin.yourdomain.com
VITE_ADMIN_URL=http://localhost:5174

# Optional fallback key used by checkout if backend does not return key_id.
# Use only Razorpay Key ID (public), never the secret.
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
