# --- Core ---
PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://user:pass@cluster.example.net/hrs3?retryWrites=true&w=majority
JWT_SECRET=use-a-long-random-string-at-least-32-chars
JWT_EXPIRE=24h

# Comma-separated browser origins (no trailing slash): storefront + admin URLs
# Example single host: https://yourdomain.com
# Example split: https://shop.example.com,https://admin.example.com
CLIENT_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
# Preferred explicit CORS env (same format). If set, this takes priority.
# ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# Optional: new signups with this email become admin
ADMIN_EMAIL=

# --- Reverse proxy (nginx, Caddy, Railway, etc.) ---
# Set to true so rate limits and req.ip use X-Forwarded-For
TRUST_PROXY=true

# Request timeout in milliseconds (server-side socket timeout)
# REQUEST_TIMEOUT_MS=30000

# DB boot retries for transient network/provider issues
# DB_CONNECT_MAX_RETRIES=5
# DB_CONNECT_RETRY_BASE_MS=2000

# Rate limits (must be >= 1)
# AUTH_RATE_LIMIT_MAX=15
# ADMIN_RATE_LIMIT_MAX=200
# RATE_LIMIT_MAX=300

# --- Optional: serve Vite builds from this API (same machine / monorepo) ---
# After `npm run build` at repo root, set true to serve client/dist and admin/dist
SERVE_STATIC=false

# --- Auth cookies (HTTPS production) ---
# Default: sameSite=lax, secure=true when NODE_ENV=production
# If API and storefront are on different sites (e.g. api.* vs www.*), use:
# COOKIE_SAME_SITE=none
# (Secure is forced when sameSite=none)
# COOKIE_SECURE=false   # only if you must use HTTP (not recommended)
# COOKIE_DOMAIN=.example.com
# COOKIE_PATH=/
# AUTH_SESSION_HOURS=24

# --- Rate limits (optional) ---
# RATE_LIMIT_DISABLED=true
# RATE_LIMIT_MAX=2000
# AUTH_RATE_LIMIT_MAX=40
# ADMIN_RATE_LIMIT_MAX=400

# --- Payments & uploads (set in production) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Optional email (contact / notifications via Resend) ---
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# Prefer RESEND_FROM (falls back to EMAIL_FROM in code):
# RESEND_FROM="HRS3 <noreply@yourdomain.com>"
# EMAIL_FROM="HRS3 <noreply@yourdomain.com>"
# EMAIL_TO=
# Optional: email verification expiry in ms (default 24h)
# EMAIL_VERIFICATION_EXPIRE_MS=86400000

# Password reset URL target and expiry
# RESET_PASSWORD_URL=https://hrs3.in
# PASSWORD_RESET_EXPIRE_MS=900000

